/*
Problem: Kadane's Algorithm
Platform: LeetCode/GFG
Difficulty: Medium
Approach: Kadane's Algorithm
Time Complexity: O(n)
Space Complexity: O(1)
*/
class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int maxi = nums[0];
        int sum = 0;

        for(int i = 0; i < nums.size(); i++){
            sum += nums[i];
            maxi = max(maxi, sum);
            
            if(sum < 0){
                sum = 0;
            }
        }
        return maxi;
    }
};